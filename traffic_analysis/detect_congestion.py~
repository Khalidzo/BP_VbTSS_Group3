import cv2
import numpy as np
from ultralytics import YOLO
from norfair import Detection, Tracker
from select_roi import ROISelector
from save_jam_results import JamResultsSaver


class TrafficJamDetector:
    def __init__(self, yolo_weights_path="Yolo-Weights/yolo12n.pt",
                 min_velocity=1,
                 jam_threshold=3, jam_frames_duration=5,
                 target_width=640, target_height=360):

        self.yolo_model = YOLO(yolo_weights_path)
        self.min_velocity = min_velocity
        self.jam_threshold = jam_threshold
        self.jam_frames_duration = jam_frames_duration
        self.target_width = target_width
        self.target_height = target_height

        # Define euclidean_distance using a lambda as it's self-contained and only used here
        self.tracker = Tracker(distance_function="euclidean", distance_threshold=30)

        # ROI-related attributes will be set after ROI selection
        self.polygons = []  # Stores list of (x,y) tuples for each ROI
        self.polygon_np_arrays = []  # Stores np.array(polygon, np.int32) for efficiency

        self.zone_stationary_counts = []
        self.zone_active_jams = []
        self.track_history = {}  # Stores last known 'cy' for each track_id, as per original logic

        self.jam_intervals = []  # List of lists, one for each zone, storing (start_frame, end_frame) tuples
        self.jam_start_frames = []  # List of start frames for active jams, one for each zone

        self.evaluation_log = []

        # Pre-define vehicle labels for faster lookup
        self.vehicle_labels = {"car", "truck", "bus", "motorbike", "bicycle"}

        # Initialize external modules
        self.roi_selector = ROISelector()
        self.results_saver = JamResultsSaver()

    def _initialize_zone_data(self, num_zones):
        """Initialize data structures for the selected zones."""
        self.zone_stationary_counts = [0] * num_zones
        self.zone_active_jams = [False] * num_zones
        self.jam_intervals = [[] for _ in range(num_zones)]
        self.jam_start_frames = [-1] * num_zones

    def run(self, video_path):
        """Runs the main traffic jam detection process on a video."""
        cap = cv2.VideoCapture(video_path)
        if not cap.isOpened():
            print(f"❌ Error: Could not open video file '{video_path}'.")
            return

        fps = cap.get(cv2.CAP_PROP_FPS)

        success, frame = cap.read()
        if not success:
            print("❌ Error: Could not read the first frame from the video.")
            cap.release()
            return

        frame = cv2.resize(frame, (self.target_width, self.target_height))

        # Use external ROI selector
        self.polygons, self.polygon_np_arrays = self.roi_selector.select_rois(frame)

        # Initialize zone data based on selected ROIs
        self._initialize_zone_data(len(self.polygons))

        cap.set(cv2.CAP_PROP_POS_FRAMES, 0)

        print("\n--- Starting Traffic Jam Detection ---")
        frame_idx = 0  # Dies ist der absolute Frame-Index im Video
        while True:
            success, frame = cap.read()
            if not success:
                break

            frame_idx += 1
            current_frame_display = cv2.resize(frame, (self.target_width, self.target_height))

            # YOLO prediction und Norfair tracking Logik
            results_boxes = self.yolo_model.predict(current_frame_display, verbose=False)[0].boxes
            norfair_detections = []
            for box in results_boxes:
                conf = float(box.conf[0])
                cls_id = int(box.cls[0])
                label = self.yolo_model.names[cls_id]
                if label in self.vehicle_labels:
                    x1, y1, x2, y2 = box.xyxy[0].tolist()
                    cx = (x1 + x2) / 2
                    cy = (y1 + y2) / 2
                    norfair_detections.append(Detection(points=np.array([[cx, cy]]), scores=np.array([conf])))

            tracked_objects = self.tracker.update(detections=norfair_detections)

            zone_stationary_this_frame = [0] * len(self.polygons)
            zone_velocities_this_frame = [[] for _ in self.polygons]

            for obj in tracked_objects:
                cx, cy = map(int, obj.estimate[0])
                track_id = obj.id
                prev_y = self.track_history.get(track_id, cy)
                velocity = abs(cy - prev_y)
                self.track_history[track_id] = cy

                is_inside_any_roi = False
                for idx, poly_np in enumerate(self.polygon_np_arrays):
                    if cv2.pointPolygonTest(poly_np, (cx, cy), False) >= 0:
                        is_inside_any_roi = True
                        if velocity < self.min_velocity:
                            zone_stationary_this_frame[idx] += 1
                        if prev_y is not None:
                            zone_velocities_this_frame[idx].append(velocity)
                        break

                track_color = (255, 0, 0) if is_inside_any_roi else (0, 255, 255)
                cv2.putText(current_frame_display, "", (cx + 8, cy - 8),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.4, track_color, 1, cv2.LINE_AA)

            for idx, polygon in enumerate(self.polygons):
                if zone_stationary_this_frame[idx] >= self.jam_threshold:
                    self.zone_stationary_counts[idx] += 1
                else:
                    if self.zone_active_jams[idx]:
                        end_frame = frame_idx - 1
                        start_frame = self.jam_start_frames[idx]
                        if start_frame != -1:
                            self.jam_intervals[idx].append((start_frame, end_frame))
                        self.jam_start_frames[idx] = -1
                    self.zone_stationary_counts[idx] = 0

                is_jam_predicted = self.zone_stationary_counts[idx] >= self.jam_frames_duration

                if is_jam_predicted and not self.zone_active_jams[idx]:
                    self.jam_start_frames[idx] = frame_idx
                self.zone_active_jams[idx] = is_jam_predicted

                color = (0, 0, 255) if is_jam_predicted else (0, 255, 0)
                cv2.polylines(current_frame_display, [self.polygon_np_arrays[idx]], isClosed=True, color=color,
                              thickness=2)
                status_text = "Traffic Jam" if is_jam_predicted else "Traffic Flowing"
                cv2.putText(current_frame_display, f"Zone {idx + 1}: {status_text}",
                            (polygon[0][0], polygon[0][1] - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2, cv2.LINE_AA)

                avg_velocity_in_zone = None
                if zone_velocities_this_frame[idx]:
                    avg_velocity_in_zone = np.mean(zone_velocities_this_frame[idx])

            cv2.imshow("Traffic Jam Detection", current_frame_display)
            if cv2.waitKey(1) & 0xFF == 27:
                break

        last_frame_idx = frame_idx
        for idx, active in enumerate(self.zone_active_jams):
            if active:
                start_frame = self.jam_start_frames[idx]
                if start_frame != -1:
                    self.jam_intervals[idx].append((start_frame, last_frame_idx))

        cap.release()
        cv2.destroyAllWindows()

        # Use external results saver
        self.results_saver.save_jam_evaluation(self.jam_intervals, fps)
        print("\n--- Traffic Jam Detection Finished ---")


if __name__ == "__main__":
    detector = TrafficJamDetector()
    detector.run(video_path="https://s52.nysdot.skyvdn.com:443/rtplive/R11_020/playlist.m3u8")